{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "preferences": {
          "type": "object",
          "properties": {
            "notificationEnabled": { "type": "boolean" },
            "adaptationSensitivity": { "type": "string", "enum": ["low", "medium", "high"] }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A habit the user wants to form",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly"] },
        "category": { "type": "string" },
        "currentLevel": { "type": "integer" },
        "isAdapted": { "type": "boolean" },
        "originalPlan": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name"]
    },
    "HabitEntry": {
      "title": "HabitEntry",
      "description": "Completion record for a habit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "habitId": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "completed": { "type": "boolean" },
        "notes": { "type": "string" },
        "wasAdapted": { "type": "boolean" }
      },
      "required": ["habitId", "userId", "date"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "users/{userId}/habits/{habitId}": {
      "schema": "Habit",
      "description": "Habits for a user"
    },
    "users/{userId}/habits/{habitId}/entries/{entryId}": {
      "schema": "HabitEntry",
      "description": "Daily logs for a habit"
    }
  }
}
